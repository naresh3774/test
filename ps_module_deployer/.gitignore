# Ignore temporary files
*.retry
*~
*.swp

# Ignore generated documentation and package builds
# (Adjust based on your specific tools)
docs/
build/

# Ignore log files
*.log

# Ignore inventory files (consider separate management)
inventory*

# Ignore virtual environment directories
.venv/
env/

# Ignore IDE/editor specific files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Ignore coverage reports
.coverage

# Ignore Ansible Vault password files
*.vault

# Ignore any potential temporary Ansible output
ansible_facts.cache
ansible_history.log
